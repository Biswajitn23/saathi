# API Configuration
# IMPORTANT: Copy this to .env.local and fill with your actual values
# NEVER commit .env or credentials to git

# Frontend API URL (leave empty for localStorage only)
VITE_API_URL=

# ============================================
# MongoDB Setup (Optional - for backend only)
# ============================================
# Get connection string from MongoDB Atlas:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a cluster
# 3. Click "Connect" and copy the connection string
# 4. Replace <username> and <password> with your credentials
# 5. Replace <cluster> with your cluster name
MONGODB_URI=

# Backend Port (default: 3000)
PORT=3000

# ============================================
# Firebase Setup (Alternative to MongoDB)
# ============================================
# Optional: Use Firebase instead of MongoDB
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=

# ============================================
# Security
# ============================================
# Add API key for backend authentication (optional)
# API_KEY=your-secret-key-here

